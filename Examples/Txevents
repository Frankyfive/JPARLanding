  <script>
document.addEventListener('DOMContentLoaded', function () {
    removeSpecificDivs();
    populateFilters();

    // Apply filters when dropdowns change
    document.getElementById('typeFilter').addEventListener('change', applyFilters);
    document.getElementById('locationFilter').addEventListener('change', applyFilters);
});

function removeSpecificDivs() {
    var divsToRemove = document.querySelectorAll('.row-fluid-wrapper.row-depth-1.row-number-6.dnd-section.dnd_area_main_banner-row-2-hidden');
    divsToRemove.forEach(function (div) {
        div.remove();
    });
}

function populateFilters() {
    const eventCards = document.querySelectorAll('.event-calendar-event-card');
    const typeSet = new Set();
    const citySet = new Set();

    eventCards.forEach(card => {
        const typeSpan = card.querySelector('.event-calendar-event-type > span');
        const type = typeSpan ? typeSpan.innerText.trim() : null;
        if (type) typeSet.add(type);

        const locationDiv = card.querySelector('.event-calendar-location-text span div');
        const fullLocation = locationDiv ? locationDiv.innerText.trim() : null;
        const city = extractCity(fullLocation);
        if (city) citySet.add(city);
    });

    populateSelect(document.getElementById('typeFilter'), typeSet);
    populateSelect(document.getElementById('locationFilter'), citySet);
}

function extractCity(fullLocation) {
    // Try to extract City from formats like "Dallas, TX 75201"
    if (!fullLocation) return null;
    const regex = /([A-Za-z\s]+),\s*[A-Z]{2}\s*\d{5}/;
    const match = fullLocation.match(regex);
    return match ? match[1].trim() : (fullLocation === "Zoom" ? "Zoom" : null);
}

function populateSelect(selectElement, values) {
    const sortedValues = Array.from(values).sort();
    // Add a blank option
    selectElement.innerHTML = '<option value="">All</option>';

    sortedValues.forEach(value => {
        let displayText = value;
        if (selectElement.id === "typeFilter") {
            displayText = toTitleCase(value);
        }
        const option = new Option(displayText, value);
        selectElement.add(option);
    });
}

function toTitleCase(str) {
    return str.replace(/\w\S*/g, function (txt) {
        return txt.charAt(0).toUpperCase() + txt.substr(1).toLowerCase();
    });
}

function applyFilters() {
    const typeFilter = document.getElementById('typeFilter').value;
    const locationFilter = document.getElementById('locationFilter').value;

    const eventCards = document.querySelectorAll('.event-calendar-event-card');
    eventCards.forEach(card => {
        const typeSpan = card.querySelector('.event-calendar-event-type > span');
        const type = typeSpan ? typeSpan.innerText.trim() : "";

        const locationDiv = card.querySelector('.event-calendar-location-text span div');
        const location = locationDiv ? locationDiv.innerText.trim() : "";
        const city = extractCity(location);

        const matchesType = !typeFilter || type === typeFilter;
        const matchesCity = !locationFilter || city === locationFilter;

        card.style.display = matchesType && matchesCity ? '' : 'none';
    });
}

function clearFilters() {
    document.getElementById('typeFilter').value = "";
    document.getElementById('locationFilter').value = "";
    applyFilters();
}
</script> 
